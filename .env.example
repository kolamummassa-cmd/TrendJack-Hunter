DJANGO_SECRET_KEY=replace-this-with-a-real-secret-key
DJANGO_DEBUG=True

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Trends below this entrepreneur-relevance score (0-100) won't get briefs generated
MIN_RELEVANCE_SCORE_FOR_BRIEF=40

# --- IntaSend payments (card + M-Pesa) ---
# Get these from your IntaSend dashboard: https://dashboard.intasend.com
INTASEND_PUBLISHABLE_KEY=ISPubKey_test_xxxxxxxx
INTASEND_SECRET_KEY=ISSecretKey_test_xxxxxxxx
INTASEND_TEST_MODE=True

# Set this to a random string, then enter the SAME string in your IntaSend
# dashboard under Settings > Webhooks, so IntaSend's webhook calls can be
# verified as genuine.
INTASEND_WEBHOOK_CHALLENGE=change-me-to-a-random-string

# Subscription prices (KES)
SUBSCRIPTION_PRICE_MONTHLY_KES=500
SUBSCRIPTION_PRICE_YEARLY_KES=5000

# --- YouTube monitoring ---
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# --- Reddit monitoring ---
REDDIT_CLIENT_ID=your-reddit-script-app-client-id
REDDIT_CLIENT_SECRET=your-reddit-script-app-secret
REDDIT_USER_AGENT=TrendjackHunter/1.0 by yourusername
